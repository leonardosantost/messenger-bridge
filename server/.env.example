PORT=3000

# Pasta onde o bridge.sqlite3 é gravado. Em Docker/EasyPanel, aponte para um
# volume persistente (ex: /app/data) para não perder o mapeamento a cada deploy.
DATA_DIR=./data

# Token que a extensão Chrome deve enviar ao conectar no WebSocket
EXTENSION_TOKEN=change-me

# Segredo compartilhado com o webhook do Chatwoot, enviado como header X-Webhook-Token.
# ATENÇÃO: o webhook nativo do Chatwoot (Settings > Integrations > Webhooks) NÃO
# permite configurar headers customizados — só a URL. Ou seja, essa variável só
# funciona se você colocar um proxy na frente que injete esse header, ou se usar
# outro mecanismo de validação (ex: IP allowlist no firewall da VPS). Na dúvida,
# deixe em branco (a checagem é pulada automaticamente quando vazia).
CHATWOOT_WEBHOOK_TOKEN=

# Configuração do Chatwoot
CHATWOOT_BASE_URL=https://app.seuchatwoot.com
CHATWOOT_INBOX_IDENTIFIER=inbox_identifier_do_inbox_api
