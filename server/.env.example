PORT=3000

# Pasta onde o bridge.sqlite3 é gravado. Em Docker/EasyPanel, aponte para um
# volume persistente (ex: /app/data) para não perder o mapeamento a cada deploy.
DATA_DIR=./data

# Token que a extensão Chrome deve enviar ao conectar no WebSocket
EXTENSION_TOKEN=change-me

# Segredo compartilhado com o webhook do Chatwoot (header X-Webhook-Token), opcional mas recomendado
CHATWOOT_WEBHOOK_TOKEN=change-me

# Configuração do Chatwoot
CHATWOOT_BASE_URL=https://app.seuchatwoot.com
CHATWOOT_INBOX_IDENTIFIER=inbox_identifier_do_inbox_api
